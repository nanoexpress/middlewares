{
  "name": "@nanoexpress/middlewares",
  "version": "1.0.0",
  "description": "Middleware packages for nanoexpress",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18.12.1"
  },
  "scripts": {
    "lint": "smartlint",
    "build": "rollup -c",
    "semantic-release": "lerna exec --concurrency 1 -- semantic-release -e semantic-release-monorepo",
    "prepare": "npm run build && husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-lerna-scopes": "^20.4.3",
    "@rollup/plugin-replace": "^6.0.3",
    "eslint-config-airlight-node": "^5.6.4",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "lint-staged-config-airlight": "^4.1.5",
    "prettier-config-airlight": "^6.0.5",
    "rollup": "^4.60.1",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "smartlint": "^7.0.7",
    "typescript": "6.0.2"
  }
}
